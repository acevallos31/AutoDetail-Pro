# Backend API URL (Render will set this automatically)
# Local: http://localhost:3000/api
# Render: https://autodetail-pro-backend.onrender.com/api
VITE_API_BASE_URL=https://autodetail-pro-backend.onrender.com/api

# API Version
VITE_API_VERSION=v1

# Supabase Configuration (from your project)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
