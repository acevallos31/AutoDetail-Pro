# ============================================================================
# ENVIRONMENT CONFIGURATION - AutoDetail Pro Backend
# Copy this file to .env and fill in your actual values
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────
# SUPABASE CONFIGURATION
# Get these values from your Supabase project settings
# ─────────────────────────────────────────────────────────────────────────

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION (PostgreSQL via Supabase)
# In Render: Set these via Environment Variables dashboard
# Render will auto-fill from Supabase credentials
# ─────────────────────────────────────────────────────────────────────────

DATABASE_HOST=db.your-project.supabase.co
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=[YOUR-SUPABASE-PASSWORD]
DATABASE_SSL=true

# ─────────────────────────────────────────────────────────────────────────
# AUTH CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────

AUTH_TYPE=supabase
# For Passport.js later:
# AUTH_TYPE=passport
# JWT_SECRET=your-secret-key-min-32-chars-long
# JWT_EXPIRY=24h
# JWT_REFRESH_EXPIRY=7d

# ─────────────────────────────────────────────────────────────────────────
# STORAGE CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────

STORAGE_TYPE=supabase
# For S3 or local storage later:
# STORAGE_TYPE=s3
# S3_BUCKET=autodetail-pro
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key

# ─────────────────────────────────────────────────────────────────────────
# NOTIFICATIONS CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────

NOTIFICATIONS_TYPE=supabase
# For other providers later:
# NOTIFICATIONS_TYPE=socket.io
# NOTIFICATIONS_TYPE=kafka

# ─────────────────────────────────────────────────────────────────────────
# WHATSAPP CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────

WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_PHONE=+1234567890

# Alternative: Meta Business WhatsApp API
# WHATSAPP_PROVIDER=meta
# META_BUSINESS_ACCOUNT_ID=your-account-id
# META_PHONE_NUMBER_ID=your-phone-number-id
# META_ACCESS_TOKEN=your-access-token

# ─────────────────────────────────────────────────────────────────────────
# EMAIL CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────

EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@autodetailpro.com

# ─────────────────────────────────────────────────────────────────────────
# APPLICATION CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000
API_VERSION=v1
API_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────
# LOGGING CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────

LOG_LEVEL=debug
LOG_FORMAT=json

# ─────────────────────────────────────────────────────────────────────────
# BUSINESS CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────

BUSINESS_NAME=AutoDetail Pro
BUSINESS_CURRENCY=ARS
BUSINESS_TIMEZONE=America/Argentina/Buenos_Aires
BOOKING_ADVANCE_DAYS=90
BOOKING_MINIMUM_NOTICE_MIN=30
CHECK_IN_GRACE_WINDOW_MIN=15

# ─────────────────────────────────────────────────────────────────────────
# PAYMENT CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────

PAYMENT_PROVIDER=stripe
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...

# ─────────────────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────────────────

CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX_REQUESTS=100

# ─────────────────────────────────────────────────────────────────────────
# DEBUG (Development Only)
# ─────────────────────────────────────────────────────────────────────────

DEBUG=false
